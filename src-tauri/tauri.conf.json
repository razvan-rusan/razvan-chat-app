{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mox-opal",
  "version": "0.1.4",
  "identifier": "com.greasefang.mox-opal",
  "build": {
    "beforeDevCommand": "deno task vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "deno task vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chat App",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
